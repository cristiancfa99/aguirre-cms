# Base de datos PostgreSQL (ej: Neon, Supabase, Vercel Postgres)
# DATABASE_URL: conexión CON pooling (host con "-pooler"). Quitá &channel_binding=require
DATABASE_URL="postgresql://neondb_owner:CLAVE@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL: conexión SIN pooling (host sin "-pooler"). Sirve para crear las tablas.
DIRECT_URL="postgresql://neondb_owner:CLAVE@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# Auth.js — generar con: npx auth secret
AUTH_SECRET="cambia-esto-por-un-secreto-largo"

# Datos de contacto
NEXT_PUBLIC_WHATSAPP="543704014443"
NEXT_PUBLIC_SITE_URL="https://www.aguirreautomatizaciones.com.ar"

# Cloudinary (Fase 3 - subida de imágenes)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
